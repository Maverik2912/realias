#!/usr/bin/env bash
# path-aliases — rewrite imports to use the most specific tsconfig alias.
#
# Usage:
#   path-aliases [options]
#
# Options:
#   -c, --tsconfig FILE   Explicit tsconfig file (skips auto-discovery).
#   -r, --root DIR        Directory to scan (default: dirname of tsconfig).
#   -e, --exts "a b c"    Space-separated extensions (default: "ts tsx js jsx").
#   -s, --skip "a b c"    Space-separated directory names to prune
#                         (default: "node_modules .git").
#   -a, --all-relative    Also rewrite imports that start with `./`. By
#                         default only `../`-style imports are touched.
#   -f, --full-scan       Scan the whole file for imports instead of
#                         stopping at the first non-import line.
#   -v, --verbose         Print every candidate tsconfig tried.
#   -h, --help            Show this help.
#
# All options can also be supplied as env vars (TSCONFIG, ROOT_DIR,
# FILE_EXTS, SKIP_DIRS); flags win when both are set.

set -uo pipefail

# Resolve symlinks so SCRIPT_DIR points at the real bin/ inside the package,
# not at node_modules/.bin/ where npm installs the symlink.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
LIB_DIR="$(cd "$SCRIPT_DIR/../lib" && pwd)"
INVOCATION_DIR="$PWD"

source "$LIB_DIR/canonicalize.sh"
source "$LIB_DIR/tsconfig.sh"
source "$LIB_DIR/aliases.sh"
source "$LIB_DIR/process.sh"
source "$LIB_DIR/walk.sh"

usage() {
  sed -n '2,/^$/p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
}

export VERBOSE=0
export INCLUDE_SIBLINGS=0
export FULL_SCAN=0

while (( $# )); do
  case "$1" in
    -c|--tsconfig)     TSCONFIG="$2"; shift 2 ;;
    --tsconfig=*)      TSCONFIG="${1#*=}"; shift ;;
    -r|--root)         ROOT_DIR="$2"; shift 2 ;;
    --root=*)          ROOT_DIR="${1#*=}"; shift ;;
    -e|--exts)         FILE_EXTS="$2"; shift 2 ;;
    --exts=*)          FILE_EXTS="${1#*=}"; shift ;;
    -s|--skip)         SKIP_DIRS="$2"; shift 2 ;;
    --skip=*)          SKIP_DIRS="${1#*=}"; shift ;;
    -a|--all-relative) INCLUDE_SIBLINGS=1; shift ;;
    -f|--full-scan)    FULL_SCAN=1; shift ;;
    -v|--verbose)      VERBOSE=1; shift ;;
    -h|--help)         usage; exit 0 ;;
    --)                shift; break ;;
    -*)                echo "Unknown option: $1" >&2; usage >&2; exit 2 ;;
    *)                 echo "Unexpected argument: $1" >&2; usage >&2; exit 2 ;;
  esac
done

if (( VERBOSE )); then
  echo "Searching for tsconfig*.json from: $INVOCATION_DIR"
  list_tsconfig_candidates "$INVOCATION_DIR" | sed 's/^/  candidate: /'
fi

discover_aliases "$INVOCATION_DIR" "${TSCONFIG:-}"

if [[ -z "${CHOSEN_TSCONFIG:-}" ]]; then
  echo "Error: no tsconfig*.json found walking up from $INVOCATION_DIR" >&2
  exit 1
fi
if [[ -z "${ALIASES_RAW:-}" ]]; then
  echo "Error: none of the discovered tsconfig*.json files defined compilerOptions.paths" >&2
  echo "       (last tried: $CHOSEN_TSCONFIG)" >&2
  exit 1
fi

ALIASES=()
while IFS= read -r __line; do
  [[ -n "$__line" ]] && ALIASES+=("$__line")
done <<< "$ALIASES_RAW"
unset __line
ROOT_DIR="${ROOT_DIR:-$(dirname "$CHOSEN_TSCONFIG")}"
ROOT_DIR="$(cd "$ROOT_DIR" && pwd)"

echo "Using tsconfig: $CHOSEN_TSCONFIG"
echo "Project root:   $ROOT_DIR"
echo "Aliases:        ${#ALIASES[@]}"
if (( VERBOSE )); then
  for entry in "${ALIASES[@]}"; do
    echo "  ${entry%%|*}  ->  ${entry#*|}"
  done
fi

walk_project

echo "Done."
